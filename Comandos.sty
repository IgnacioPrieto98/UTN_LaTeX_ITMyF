% Comando para un TColorbox de ejemplo.
\newcounter{ejem}[chapter]

% Longitudes
\newlength{\Fcorta}
\setlength{\Fcorta}{0.55\linewidth}

% --- DEFINICIÓN DE TCOLORBOX --- %

% Recuadro de definiciones.

\newtcolorbox{defs}{colback=blue!5!white, arc = 0pt, boxrule=0pt,colframe= white}
\newtcolorbox{norm}{colback=red!10!white, arc = 0pt, boxrule=0pt,colframe= white,breakable, fontupper = \footnotesize}


% Recuadro de ejemplos.

\newtcolorbox{Ejem}[1]{breakable, coltitle = white,colbacktitle = colorS,title = {\footnotesize Ejemplo \thechapter.\theejem\ - #1},parbox=false, colframe = white, colback = black!05,arc = 0pt,step = ejem}



% --- DEFINICIÓN DE TABLAS Y COLUMNAS --- %

